    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/node-forge": "^1.3.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
